generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Multi-Tenant ---

model Tenant {
  id            String   @id @default(cuid())
  name          String
  adresse       String?
  logo          String?
  steuernummer  String?
  ustId         String?  @map("ust_id")
  bankName      String?  @map("bank_name")
  bankIban      String?  @map("bank_iban")
  bankBic       String?  @map("bank_bic")
  ustSatz           Decimal  @default(19.0) @map("ust_satz") @db.Decimal(5, 2)
  zahlungszielTage  Int      @default(14) @map("zahlungsziel_tage")
  sprache           String   @default("de")
  waehrung          String   @default("EUR")
  land              String   @default("DE")
  emailConfig       Json?    @map("email_config")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  users                User[]
  kunden               Kunde[]
  angebote             Angebot[]
  rechnungen           Rechnung[]
  nummernkreise        Nummernkreis[]
  chatHistory          ChatHistory[]
  maintenanceObjects   MaintenanceObject[]
  maintenanceContracts MaintenanceContract[]
  technicians          Technician[]
  annualPlans          AnnualPlan[]

  @@map("tenants")
}

// --- Benutzer ---

enum UserRole {
  ADMIN
  MITARBEITER
}

model User {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  role          UserRole @default(MITARBEITER)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

// --- Kunden ---

model Kunde {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  name          String
  adresse       String?
  email         String?
  telefon       String?
  ustId         String?  @map("ust_id")
  steuernummer  String?
  notizen       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  angebote      Angebot[]
  rechnungen    Rechnung[]

  @@index([tenantId])
  @@map("kunden")
}

// --- Angebote ---

enum AngebotStatus {
  ENTWURF
  GESENDET
  ANGENOMMEN
  ABGELEHNT
}

model Angebot {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  kundeId       String        @map("kunde_id")
  nummer        String
  status        AngebotStatus @default(ENTWURF)
  netto         Decimal       @default(0) @db.Decimal(10, 2)
  ust           Decimal       @default(0) @db.Decimal(10, 2)
  brutto        Decimal       @default(0) @db.Decimal(10, 2)
  gueltigBis    DateTime?     @map("gueltig_bis")
  archiviertAm  DateTime?     @map("archiviert_am")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kunde         Kunde         @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  positionen    AngebotPosition[]
  historie      AngebotHistorie[]
  rechnungen    Rechnung[]

  @@unique([tenantId, nummer])
  @@index([tenantId])
  @@index([status])
  @@map("angebote")
}

model AngebotPosition {
  id            String   @id @default(cuid())
  angebotId     String   @map("angebot_id")
  beschreibung  String
  menge         Decimal  @db.Decimal(10, 4)
  einheit       String   @default("Stk")
  einzelpreis   Decimal  @db.Decimal(10, 2)
  gesamtpreis   Decimal  @db.Decimal(10, 2)
  ustSatz       Decimal  @default(19.0) @map("ust_satz") @db.Decimal(5, 2)
  ustBetrag     Decimal  @default(0) @map("ust_betrag") @db.Decimal(10, 2)
  sortierung    Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  angebot       Angebot  @relation(fields: [angebotId], references: [id], onDelete: Cascade)

  @@map("angebot_positionen")
}

model AngebotHistorie {
  id            String   @id @default(cuid())
  angebotId     String   @map("angebot_id")
  quelle        String   // "voice" | "chat" | "manuell"
  wasGeaendert  String   @map("was_geaendert")
  alterWert     String?  @map("alter_wert")
  neuerWert     String?  @map("neuer_wert")
  createdAt     DateTime @default(now()) @map("created_at")

  angebot       Angebot  @relation(fields: [angebotId], references: [id], onDelete: Cascade)

  @@map("angebot_historie")
}

// --- Rechnungen ---

enum RechnungStatus {
  ENTWURF
  GESENDET
  BEZAHLT
  UEBERFAELLIG
  MAHNUNG
}

model Rechnung {
  id            String         @id @default(cuid())
  tenantId      String         @map("tenant_id")
  kundeId       String         @map("kunde_id")
  angebotId     String?        @map("angebot_id")
  nummer        String
  status        RechnungStatus @default(ENTWURF)
  netto         Decimal        @default(0) @db.Decimal(10, 2)
  ust           Decimal        @default(0) @db.Decimal(10, 2)
  brutto        Decimal        @default(0) @db.Decimal(10, 2)
  zahlungsziel  DateTime?
  bezahltAm     DateTime?      @map("bezahlt_am")
  leistungVon   DateTime?      @map("leistung_von")
  leistungBis   DateTime?      @map("leistung_bis")
  gesperrt      Boolean        @default(false)
  archiviertAm  DateTime?      @map("archiviert_am")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kunde         Kunde          @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  angebot       Angebot?       @relation(fields: [angebotId], references: [id], onDelete: SetNull)
  positionen    RechnungPosition[]
  historie      RechnungHistorie[]

  @@unique([tenantId, nummer])
  @@index([tenantId])
  @@index([status])
  @@map("rechnungen")
}

model RechnungPosition {
  id            String   @id @default(cuid())
  rechnungId    String   @map("rechnung_id")
  beschreibung  String
  menge         Decimal  @db.Decimal(10, 4)
  einheit       String   @default("Stk")
  einzelpreis   Decimal  @db.Decimal(10, 2)
  gesamtpreis   Decimal  @db.Decimal(10, 2)
  ustSatz       Decimal  @default(19.0) @map("ust_satz") @db.Decimal(5, 2)
  ustBetrag     Decimal  @default(0) @map("ust_betrag") @db.Decimal(10, 2)
  sortierung    Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  rechnung      Rechnung @relation(fields: [rechnungId], references: [id], onDelete: Cascade)

  @@map("rechnung_positionen")
}

model RechnungHistorie {
  id            String   @id @default(cuid())
  rechnungId    String   @map("rechnung_id")
  quelle        String
  wasGeaendert  String   @map("was_geaendert")
  alterWert     String?  @map("alter_wert")
  neuerWert     String?  @map("neuer_wert")
  createdAt     DateTime @default(now()) @map("created_at")

  rechnung      Rechnung @relation(fields: [rechnungId], references: [id], onDelete: Cascade)

  @@map("rechnung_historie")
}

// --- Nummernkreise ---

model Nummernkreis {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  typ           String   // "ANGEBOT" | "RECHNUNG"
  jahr          Int
  letzteNummer  Int      @default(0) @map("letzte_nummer")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, typ, jahr])
  @@index([tenantId])
  @@map("nummernkreise")
}

// --- Chat-History ---

model ChatHistory {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  quelle            String   // "voice" | "text"
  nachricht         String
  antwort           String?
  intent            String?
  kontext           Json?
  verknuepfteAktion Json?    @map("verknuepfte_aktion")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("chat_history")
}

// --- Wartungsmanager ---

enum ContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PlanStatus {
  DRAFT
  RELEASED
  EXECUTING
  COMPLETED
}

enum EntryStatus {
  PLANNED
  MANUALLY_ADJUSTED
  DONE
  CANCELLED
}

model MaintenanceObject {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String
  address      String
  city         String
  postalCode   String   @map("postal_code")
  buildingType String   @map("building_type")
  contactName  String?  @map("contact_name")
  contactPhone String?  @map("contact_phone")
  accessNotes  String?  @map("access_notes")
  createdAt    DateTime @default(now()) @map("created_at")

  contracts    MaintenanceContract[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("maintenance_objects")
}

model MaintenanceContract {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  objectId       String         @map("object_id")
  contractNumber String?        @map("contract_number")
  customerName   String         @map("customer_name")
  startDate      DateTime       @map("start_date")
  endDate        DateTime?      @map("end_date")
  autoRenew      Boolean        @default(false) @map("auto_renew")
  notes          String?
  status         ContractStatus @default(ACTIVE)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  leases         MaintenanceLease[]
  object         MaintenanceObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([objectId])
  @@map("maintenance_contracts")
}

model MaintenanceLease {
  id                    String   @id @default(cuid())
  contractId            String   @map("contract_id")
  serviceType           String   @map("service_type")
  intervalMonths        Int      @map("interval_months")
  estimatedHours        Float    @map("estimated_hours")
  qualificationRequired String?  @map("qualification_required")
  seasonalPreference    String?  @map("seasonal_preference")
  legalBasis            String?  @map("legal_basis")
  legalDeadline         String?  @map("legal_deadline")

  planEntries AnnualPlanEntry[]
  contract    MaintenanceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("maintenance_leases")
}

model Technician {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  name           String
  qualifications String[]
  workHoursStart String   @default("07:00") @map("work_hours_start")
  workHoursEnd   String   @default("16:00") @map("work_hours_end")
  maxDailyHours  Float    @default(8.0) @map("max_daily_hours")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  planEntries AnnualPlanEntry[]
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("technicians")
}

model AnnualPlan {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  year      Int
  status    PlanStatus @default(DRAFT)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  entries AnnualPlanEntry[]
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year])
  @@index([tenantId])
  @@map("annual_plans")
}

model AnnualPlanEntry {
  id              String      @id @default(cuid())
  planId          String      @map("plan_id")
  leaseId         String      @map("lease_id")
  technicianId    String      @map("technician_id")
  scheduledDate   DateTime    @map("scheduled_date")
  estimatedHours  Float       @map("estimated_hours")
  status          EntryStatus @default(PLANNED)
  conflictStatus  String?     @map("conflict_status")
  conflictDetails String?     @map("conflict_details")
  aiReasoning     String?     @map("ai_reasoning")

  plan       AnnualPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  lease      MaintenanceLease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  technician Technician       @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([technicianId])
  @@index([leaseId])
  @@index([scheduledDate])
  @@index([technicianId, scheduledDate])
  @@map("annual_plan_entries")
}
