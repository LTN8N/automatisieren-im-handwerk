{
  "name": "automatisieren-im-handwerk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:db:up": "docker compose -f docker/docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker/docker-compose.test.yml down",
    "test:setup": "pnpm test:db:up && pnpm prisma db push --skip-generate",
    "test:ci": "pnpm prisma db push --skip-generate && vitest run tests/unit && playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.4.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.9.0",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.0.0"
  }
}
