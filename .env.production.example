# ============================================================
# PRODUKTIONS-UMGEBUNGSVARIABLEN — automatisieren-im-handwerk
# ============================================================
# Diese Datei ist ein Template. Kopieren und ausfüllen:
#   cp .env.production.example .env.production
# .env.production ist in .gitignore — NIEMALS committen!
# ============================================================

# --- Domain ---
DOMAIN=automatisieren-im-handwerk.de

# --- Datenbank (GoBD-Compliance: Daten müssen 10 Jahre erhalten bleiben) ---
# Verbindung für die App (intern via Docker-Netzwerk)
DATABASE_URL=postgresql://handwerk:SICHERES_PASSWORT@postgres:5432/handwerk?schema=public

# PostgreSQL Container-Variablen
POSTGRES_USER=handwerk
POSTGRES_PASSWORD=SICHERES_PASSWORT
POSTGRES_DB=handwerk

# --- Authentifizierung ---
# PFLICHT: min. 32 Zeichen — generieren mit: openssl rand -base64 32
AUTH_SECRET=HIER_MINDESTENS_32_ZEICHEN_ZUFALLSSTRING
AUTH_URL=https://automatisieren-im-handwerk.de
AUTH_TRUST_HOST=true

# --- KI-APIs (Kosten-Monitoring Pflicht — Ausgaben täglich prüfen) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- E-Mail / Rechnungsversand (UStG §14: Rechnungen müssen zustellbar sein) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=rechnungen@automatisieren-im-handwerk.de
SMTP_PASS=SMTP_PASSWORT
SMTP_FROM=rechnungen@automatisieren-im-handwerk.de
SMTP_SECURE=false

# --- GitHub Container Registry (für CD-Deployment) ---
# Wird automatisch von GitHub Actions gesetzt — hier nur für manuelle Deployments
GITHUB_REPOSITORY=automatisieren-im-handwerk/automatisieren-im-handwerk
IMAGE_TAG=latest
